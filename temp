import torch
import torch.nn as nn
import torch.nn.functional as F
from torch import Tensor
from torch.nn import Parameter
import aimet_modules
from typing import Optional

def create_quantizable_multihead_attention(
    module: nn.MultiheadAttention,
) -> 'QuantizableMultiheadAttention':
    """
    Create QuantizableMultiheadAttention using existing torch.nn.MultiheadAttention module
    :param module: Existing torch.nn.MultiheadAttention module
    :return: Newly created QuantizableMultiheadAttention module
    """
    # Determine flags from original module
    bias = module.in_proj_bias is not None
    add_bias_kv = (module.bias_k is not None and module.bias_v is not None)

    # Instantiate new quantizable MHA
    q_MHA = QuantizableMultiheadAttention(
        embed_dim=module.embed_dim,
        num_heads=module.num_heads,
        dropout=module.dropout,
        bias=bias,
        add_bias_kv=add_bias_kv,
        add_zero_attn=module.add_zero_attn,
        kdim=module.kdim,
        vdim=module.vdim,
        batch_first=module.batch_first,
    )

    # Copy weights and biases
    with torch.no_grad():
        # Split in_proj weight into Q, K, V
        if module.in_proj_weight is not None:
            w_q, w_k, w_v = torch.chunk(module.in_proj_weight.data, 3, dim=0)
        else:
            w_q = module.q_proj_weight.data
            w_k = module.k_proj_weight.data
            w_v = module.v_proj_weight.data

        q_MHA.linear_Q.weight.copy_(w_q)
        q_MHA.linear_K.weight.copy_(w_k)
        q_MHA.linear_V.weight.copy_(w_v)
        q_MHA.out_proj.weight.copy_(module.out_proj.weight.data)

        if bias:
            # in_proj_bias splits
            b_q, b_k, b_v = torch.chunk(module.in_proj_bias.data, 3, dim=0)
            # set projection biases
            q_MHA.linear_Q.bias.copy_(b_q)
            q_MHA.linear_K.bias.copy_(b_k)
            q_MHA.linear_V.bias.copy_(b_v)
            # if original module had separate bias_k/v, copy those too
            if add_bias_kv:
                q_MHA.bias_k.copy_(module.bias_k.data)
                q_MHA.bias_v.copy_(module.bias_v.data)
            # out_proj bias
            q_MHA.out_proj.bias.copy_(module.out_proj.bias.data)

    return q_MHA


class QuantizableMultiheadAttention(nn.MultiheadAttention):
    """Quantizable implementation of torch.nn.MultiheadAttention"""
    _FLOAT_MODULE = nn.MultiheadAttention

    def __init__(
        self,
        embed_dim: int,
        num_heads: int,
        dropout: float = 0.0,
        bias: bool = True,
        add_bias_kv: bool = False,
        add_zero_attn: bool = False,
        kdim: int = None,
        vdim: int = None,
        batch_first: bool = False,
        **factory_kwargs,
    ) -> None:
        super().__init__(embed_dim, num_heads, dropout, bias,
                         add_bias_kv, add_zero_attn, kdim, vdim,
                         batch_first, **factory_kwargs)
        # Replace in_proj with explicit linears
        self.linear_Q = nn.Linear(embed_dim, embed_dim, bias=bias, **factory_kwargs)
        self.linear_K = nn.Linear(self.kdim, embed_dim, bias=bias, **factory_kwargs)
        self.linear_V = nn.Linear(self.vdim, embed_dim, bias=bias, **factory_kwargs)
        # Override out_proj with standard Linear
        self.out_proj = nn.Linear(embed_dim, embed_dim, bias=bias, **factory_kwargs)

        # AIMET operations for quantization hooks
        self.div = aimet_modules.Divide()
        self.matmul_1 = aimet_modules.MatMul()
        self.matmul_2 = aimet_modules.MatMul()
        self.mask_add = aimet_modules.Add()
        self.softmax = nn.Softmax(dim=-1)

    def _get_name(self):
        return "QuantizableMultiheadAttention"

    def forward(
        self,
        query: Tensor,
        key: Tensor,
        value: Tensor,
        key_padding_mask: Optional[Tensor] = None,
        need_weights: bool = True,
        attn_mask: Optional[Tensor] = None,
        average_attn_weights: bool = True,
        is_causal: bool = False,
    ) -> Tuple[Tensor, Optional[Tensor]]:
        return self._forward_impl(query, key, value,
                                  key_padding_mask, need_weights,
                                  attn_mask, average_attn_weights)

    def _forward_impl(
        self,
        query: Tensor,
        key: Tensor,
        value: Tensor,
        key_padding_mask: Optional[Tensor] = None,
        need_weights: bool = True,
        attn_mask: Optional[Tensor] = None,
        average_attn_weights: bool = True,
    ) -> Tuple[Tensor, Optional[Tensor]]:
        # Prepare shapes
        if self.batch_first:
            # transpose to (seq_len, batch, embed_dim)
            query, key, value = [t.transpose(0, 1) for t in (query, key, value)]
        tgt_len, bsz, _ = query.size()

        # Linear projections
        q = self.div(self.linear_Q(query), float((self.embed_dim // self.num_heads) ** 0.5))
        k = self.linear_K(key)
        v = self.linear_V(value)

        # Handle masks
        if key_padding_mask is not None and key_padding_mask.dtype == torch.uint8:
            key_padding_mask = key_padding_mask.to(torch.bool)
        if attn_mask is not None:
            if attn_mask.dtype == torch.uint8:
                attn_mask = attn_mask.to(torch.bool)
            if attn_mask.dim() == 2:
                attn_mask = attn_mask.unsqueeze(0)

        # Reshape for heads: (batch*num_heads, seq_len, head_dim)
        head_dim = self.embed_dim // self.num_heads
        q = q.contiguous().view(tgt_len, bsz * self.num_heads, head_dim).transpose(0, 1)
        k = k.contiguous().view(-1, bsz * self.num_heads, head_dim).transpose(0, 1)
        v = v.contiguous().view(-1, bsz * self.num_heads, head_dim).transpose(0, 1)

        # Compute attention scores
        attn_weights = self.matmul_1(q, k.transpose(1, 2))
        if attn_mask is not None:
            if attn_mask.dtype == torch.bool:
                attn_weights.masked_fill_(attn_mask, float('-inf'))
            else:
                self.mask_add(attn_weights, attn_mask)
        if key_padding_mask is not None:
            attn_weights = attn_weights.view(bsz, self.num_heads, tgt_len, -1)
            attn_weights = attn_weights.masked_fill(
                key_padding_mask.unsqueeze(1).unsqueeze(2), float('-inf')
            ).view(bsz * self.num_heads, tgt_len, -1)

        # Softmax and dropout
        attn_weights = self.softmax(attn_weights)
        attn_weights = F.dropout(attn_weights, p=self.dropout, training=self.training)

        # Weighted sum
        attn_output = self.matmul_2(attn_weights, v)

        # Recombine heads
        if self.batch_first:
            attn_output = attn_output.view(bsz, self.num_heads, tgt_len, head_dim)
            attn_output = attn_output.transpose(1, 2).contiguous().view(bsz, tgt_len, self.embed_dim)
        else:
            attn_output = attn_output.transpose(0, 1).contiguous().view(tgt_len, bsz, self.embed_dim)

        # Final projection
        attn_output = self.out_proj(attn_output)

        # Return weights if needed
        if not need_weights:
            return attn_output, None
        attn_weights = attn_weights.view(bsz, self.num_heads, tgt_len, -1)
        if average_attn_weights:
            attn_weights = attn_weights.mean(dim=1)
        return attn_output, attn_weights
